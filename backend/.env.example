# Base URL of the Alfred deployment platform.
ALFRED_BASE_URL=https://alfred-production-fdeb.up.railway.app

# API key used by Domo / BI tools to read saved tracker records.
# Set this to a strong secret value and do not commit it.
# TRACKER_API_KEY=your-secure-tracker-api-key

# Optional: path to cache the acquired Alfred access token (gitignored).
# ALFRED_TOKEN_FILE=.alfred_token.json
